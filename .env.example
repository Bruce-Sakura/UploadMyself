# UploadMyself 环境变量配置

# === 服务配置 ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-string

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://uploadmyself:uploadmyself@localhost:5432/uploadmyself

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MinIO 对象存储 ===
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploadmyself

# === 模型 Provider ===
# local | cloud | hybrid
PROVIDER_MODE=local

# 云端 API Keys (cloud/hybrid 模式使用)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=
ELEVENLABS_API_KEY=
FISH_AUDIO_API_KEY=
HEYGEN_API_KEY=
TRIPO3D_API_KEY=

# === 本地模型路径 ===
MODEL_DIR=./ml/models
LLM_MODEL_PATH=./ml/models/base/llm
VOICE_MODEL_DIR=./ml/models/voice
AVATAR_MODEL_DIR=./ml/models/avatar_2d

# === GPU 配置 ===
CUDA_VISIBLE_DEVICES=0
TORCH_DEVICE=cuda

# === 日志 ===
LOG_LEVEL=INFO
