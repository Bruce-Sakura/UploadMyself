# UploadMyself 配置（install.sh 会据此生成 .env）

# 运行时工作目录（数据库/uploads/skills/模型都存这里）
# install.sh 默认写入 ~/.UploadMyself 的绝对路径
UPLOADMYSELF_HOME=/root/.UploadMyself

# 服务端口
APP_PORT=8000

# 数据库：SQLite 单文件（Docker 模式由 compose 内部固定为 /app/data/uploadmyself.db）
# 原生模式下指向工作目录，例如 ~/.UploadMyself/data/db/uploadmyself.db
DB_PATH=/root/.UploadMyself/data/db/uploadmyself.db

# LLM 配置（小米 MiMo API，或任意 OpenAI 兼容服务）
LLM_API_KEY=你的API密钥
LLM_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
LLM_MODEL=mimo-v2.5-pro

# ML 脚本（容器内路径，通常无需改）
PYTHON_BIN=python3
ML_SCRIPTS_DIR=/app/ml/scripts
SKILLS_DIR=/app/skills
UPLOAD_DIR=/app/uploads
ML_SERVICE_URL=http://localhost:8001
